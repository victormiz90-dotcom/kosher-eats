# Supabase (get these from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Maps & Places (one key is fine, just restrict it properly)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_PLACES_API_KEY=your-google-places-key

# Affiliate tracking (Impact partner IDs once approved)
UBEREATS_IMPACT_PARTNER_ID=
DOORDASH_IMPACT_PARTNER_ID=
GRUBHUB_CJ_AFFILIATE_ID=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_ZIP=11230
